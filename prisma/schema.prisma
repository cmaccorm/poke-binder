generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// A physical binder with a fixed page layout
model Binder {
  id            String   @id @default(cuid())
  nickname      String
  color         String   @default("#3B82F6") // tailwind blue-500
  layoutRows    Int      // 2, 3, or 4
  layoutCols    Int      // 2 or 3
  lastViewedPage Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pages Page[]
}

/// A single page within a binder
model Page {
  id        String @id @default(cuid())
  pageIndex Int    // 0-based page number within the binder

  binderId String
  binder   Binder @relation(fields: [binderId], references: [id], onDelete: Cascade)

  slots Slot[]

  @@unique([binderId, pageIndex])
}

/// A slot at a specific row/col position on a page
model Slot {
  id  String @id @default(cuid())
  row Int    // 0-based row within the page layout
  col Int    // 0-based column within the page layout

  pageId String
  page   Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)

  catalogCardId String?
  catalogCard   CatalogCard? @relation(fields: [catalogCardId], references: [id])
  variant       String?      // e.g. "Normal", "Holo", "Reverse Holo", "1st Edition Holo"

  @@unique([pageId, row, col])
}

/// Cached card data from the external catalog
model CatalogCard {
  id           String   @id @default(cuid())
  externalId   String   @unique // ID from the catalog API (e.g. pokemontcg.io)
  name         String
  number       String   // card number within the set
  setName      String
  setId        String
  imageSmall   String   // thumbnail URL
  imageLarge   String   // full-size URL
  rarity          String?
  priceTcgplayer  Float?
  priceCardmarket Float?
  priceUpdatedAt  DateTime?
  cachedAt        DateTime @default(now())

  slots Slot[]

  @@index([name])
  @@index([number])
}

/// Custom per-variant card image overrides (e.g. reverse holo photography)
model CustomCardImage {
  id         String   @id @default(cuid())
  externalId String
  variant    String
  imageSmall String
  imageLarge String
  createdAt  DateTime @default(now())

  @@unique([externalId, variant])
  @@index([externalId])
}

/// Cached Cardmarket pricing trend data from TCGdex API (1/7/30-day averages)
model PriceTrend {
  id         String   @id @default(cuid())
  externalId String   @unique
  data       String   // JSON blob of TCGdex pricing.cardmarket object
  fetchedAt  DateTime @default(now())
}
